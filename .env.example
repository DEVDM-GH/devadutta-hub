# ─── NextAuth ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
NEXTAUTH_SECRET=

# Local dev
NEXTAUTH_URL=http://localhost:3000
# Production (update after Vercel deployment)
# NEXTAUTH_URL=https://your-app.vercel.app

# ─── Google OAuth ─────────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Access Control ───────────────────────────────────────────
# Comma-separated list of allowed Google emails
ALLOWED_EMAILS=qa.devadutta@gmail.com,talk2devdmohapatra@gmail.com

# ─── Database ─────────────────────────────────────────────────
# Local: Prisma CLI uses prisma.config.ts → file:./prisma/dev.db (npm run db:migrate)
# Remote: after first migrate locally, push schema to Turso once:
#   npm run db:apply-turso
# (Requires Node 20+; loads these from .env.local)

TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# ─── AI (optional — for future AI generation features) ────────
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
